<!DOCTYPE html>
<html lang="nl">
<!-- Chart.js library voor grafieken op de homepage -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BackOffice</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BackOffice.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">

            <!-- SIDEBAR -->
            <nav class="sidebar">
                <div class="sidebar-brand">
                    <i class="bi bi-gear-fill"></i>
                    <span>BackOffice</span>
                </div>
                <!-- Nav links: Home, Personeel, Producten, Orders -->
                <ul class="sidebar-nav">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="active">
                            <i class="bi bi-house"></i>
                            <span>Home</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="Personeel">
                            <i class="bi bi-people"></i>
                            <span>Personeel</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="Producten">
                            <i class="bi bi-box-seam"></i>
                            <span>Producten</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Order" asp-action="Index">
                            <i class="bi bi-cart"></i>
                            <span>Orders</span>
                        </a>
                    </li>
                </ul>
                <!-- Uitloggen onderaan -->
                <div class="mt-auto">
                    <a asp-controller="Home" asp-action="Login" class="sidebar-logout">
                        <i class="bi bi-box-arrow-left"></i>
                        <span>Uitloggen</span>
                    </a>
                </li>
            </ul>
            <!-- Uitloggen onderaan -->
            <div class="mt-auto">
                <a href="@(Url.Action("Login","Home"))" class="sidebar-logout @(ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : "")">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Uitloggen</span>
                </a>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="flex-grow-1 p-4" style="background-color: #f0f2f5;">
            @RenderBody()
        </main>

    </div>
    <!-- scripts -->
    <script src="~/js/chart.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>