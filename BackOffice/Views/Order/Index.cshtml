@model OrderViewModel;
@{
    ViewData["Title"] = "Orders";
}

<link rel="stylesheet" href="~/css/order.css" asp-append-version="true" />

<body>

    <div class="page">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span>›</span>
            <span>Orders</span>
        </div>

        <h1>Orders</h1>

        <div class="toolbar">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Zoeken...">
            </div>

            <select id="statusFilter">
                <option value="all">Alle</option>
                <option value="Voltooid">Voltooid</option>
                <option value="In behandeling">In behandeling</option>
                <option value="Verzonden">Verzonden</option>
                <option value="Geannuleerd">Geannuleerd</option>
            </select>

            <div class="results">
                <span id="resultsCount">@Model.Orders.Count()</span> resultaten
            </div>
        </div>

        <div class="orders-table" id="ordersTable">
            <div class="table-header table-row">
                <div>NAAM</div>
                <div>KLANT</div>
                <div>DATUM</div>
                <div>TIJD</div>
                <div>STATUS</div>
                <div>BEDRAG</div>
                <div></div>
            </div>
            
            @foreach (OrderWithTotal order in Model.Orders)
            {
                <a asp-controller="Order" asp-action="OrderDetails" asp-route-id="@order.Order.Id" class="table-row order-data-row">
                    <div class="order-name">@order.Order.Name</div>
                    <div>@order.Order.User.Name</div>
                    <div>@order.Order.OrderDate</div>
                    <div>@order.Order.OrderTime</div>
                    <div>@order.Order.OrderStatus</div>
                    <div>€@order.TotalPrice</div>
                    <div class="arrow">›</div>
                </a>
            }
        </div>
    </div>

</body>
<script src="~/js/orderfilter.js"></script>