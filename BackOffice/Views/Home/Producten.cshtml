@model BackOffice.DataAccessLayer.Models.PaginatedProductViewModel;
@{
    ViewData["Title"] = "Producten";
    Layout = "_Layout";
}
<head>
    <script>
        // ---- producten bulk ----

        // Submit the bulk form with the chosen action
        function submitBulk(action) {
            const checked = document.querySelectorAll('.bulk-checkbox:checked');
            if (checked.length === 0) {
                alert('Select at least one product.');
                return;
            }
            document.getElementById('bulkActionType').value = action;
            document.getElementById('bulkForm').submit();
        }

        // Individual remove — posts a tiny separate form dynamically
        function submitRemove(id) {
            if (!confirm('Remove this product?')) return;
            const f = document.createElement('form');
            f.method = 'post';
            f.action = '/Producten/Remove';
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'id';
            input.value = id;
            f.appendChild(input);
            document.body.appendChild(f);
            f.submit();
        }
    </script>
</head>
<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center mb-3">
        <h2 class="me-3">Producten</h2>
    </div>

    <!-- Sub-navbar: Voorraad overzicht | Categorieën -->
    <div class="product-subnav mb-4">
        <nav class="nav align-items-center">
            <a asp-controller="Home" asp-action="Producten" class="nav-link subnav-link active">
                <i class="bi bi-layout-text-window-reverse me-2"></i>
                Voorraad overzicht
            </a>
            <a asp-controller="Producten" asp-action="Categories" class="nav-link subnav-link">
                <i class="bi bi-tags me-2"></i>
                Categorieën
            </a>
        </nav>
    </div>

    <div class="row g-3 mb-4 products-top-cards">
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Op voorraad</small>
                        <div class="h5 mb-0">@Model.OnStockCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-green"><i class="bi bi-check-lg"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Laag voorraad</small>
                        <div class="h5 mb-0">@Model.LowCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-blue"><i class="bi bi-exclamation-lg"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Niet op voorraad</small>
                        <div class="h5 mb-0">@Model.OutCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-red"><i class="bi bi-x-lg"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="products-table-card card w-100">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-3 gap-3">
                <form class="search-form flex-grow-1 me-3" method="get" asp-action="Product">
                    <div class="input-group search-group">
                        <span class="input-group-text search-icon"><i class="bi bi-search"></i></span>
                        <input name="q" value="@(ViewContext.HttpContext.Request.Query["q"])" type="text" class="form-control search-input" placeholder="Zoeken op naam, categorie of SKU..." />
                    </div>
                </form>
                <div class="text-muted ms-2">@Model.TotalCount artikelen</div>
            </div>

            <form asp-controller="Producten" asp-action="BulkAction" method="post" id="bulkForm" class"table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><!--Empty--></th>
                            <th>ID</th>
                            <th>Naam</th>
                            <th>SKU</th>
                            <th>Categorie</th>
                            <th>Locatie</th>
                            <th class="text-end">Voorraad</th>
                            <th class="text-end">Min.</th>
                            <th class="text-end">Prijs/st.</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Edit</th>
                            <th class="text-end">Verwijder</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var product in Model.Items)
                    {
                            string badgeClass = product.Status == "Op voorraad" ? "status-success" : product.Status == "Laag voorraad" ? "status-warning" : "status-danger";
                            string iconClass = product.Status == "Op voorraad" ? "bi-check-circle" : product.Status == "Laag voorraad" ? "bi-exclamation-triangle" : "bi-x-circle";

                        <tr class="product">
                            <td>    
                                <input type="checkbox" class="bulk-checkbox" name="selectedIds" value="@product.Id" />
                            </td>
                            <td>@product.Id</td>
                            <td>@product.Name</td>
                                <td class="text-muted">@product.SKU</td>
                            <td>@product.Category</td>
                            <td>@product.Location</td>
                                <td class="text-end">@product.Availability</td>
                            <td class="text-end">@product.MinimumAvailablility</td>
                                <td class="text-end">@product.Price</td>
                            <td class="text-center">
                                <span class="badge status-badge @badgeClass"><i class="bi @iconClass me-1"></i> @product.Status</span>
                            </td>
                            <td class="text-end">
                                <a asp-controller="Producten" asp-action="Edit" asp-route-id="@product.Id" class="edit-product">Edit</a>
                            </td>
                            <td class="text-end">
                                <button type="button" class="remove-product" hx-post="/Producten/Remove/@product.Id" onclick="submitRemove(@product.Id)">Remove</button>
                            </td>
                        </tr>
                    }
                    </tbody>


                </table>
                <!-- Hidden field to carry which button was clicked -->
                <input type="hidden" name="action" id="bulkActionType" value="" />

                <button type="button" class="bulk-action" onclick="submitBulk('edit')">Edit Selected</button>
                <button type="button" class="bulk-action" onclick="submitBulk('delete')">Delete Selected</button>
            </form>
            
            </div>

            <div class="d-flex justify-content-end mt-3">
                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            var active = i == Model.Page ? "active" : "";
                            <li class="page-item @active">
                                <a class="page-link" href="@(Url.Action("Product", new { q = ViewContext.HttpContext.Request.Query["q"], page = i, pageSize = Model.PageSize }))">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>