@model BackOffice.DataAccessLayer.Models.PaginatedProductViewModel;
@{
    ViewData["Title"] = "Producten";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center mb-3">
        <h2 class="me-3">Producten</h2>
    </div>

    <!-- Sub-navbar: Voorraad overzicht | Voorraadbeheer | Categorieën -->
    <div class="product-subnav mb-4">
        <nav class="nav align-items-center">
            <a asp-controller="Home" asp-action="Product" class="nav-link subnav-link active">
                <i class="bi bi-layout-text-window-reverse me-2"></i>
                Voorraad overzicht
            </a>
            <a asp-controller="Home" asp-action="VoorraadBeheer" class="nav-link subnav-link">
                <i class="bi bi-tools me-2"></i>
                Voorraad beheer
            </a>
            <a asp-controller="Home" asp-action="Categorieen" class="nav-link subnav-link">
                <i class="bi bi-tags me-2"></i>
                Categorieën
            </a>
        </nav>
    </div>

    <div class="row g-3 mb-4 products-top-cards">
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Op voorraad</small>
                        <div class="h5 mb-0">@Model.OnStockCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-green"><i class="bi bi-check-lg"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Laag voorraad</small>
                        <div class="h5 mb-0">@Model.LowCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-blue"><i class="bi bi-exclamation-lg"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 stat-card">
                <div class="d-flex align-items-center">
                    <div class="flex-grow-1">
                        <small class="text-muted">Niet op voorraad</small>
                        <div class="h5 mb-0">@Model.OutCount artikelen</div>
                    </div>
                    <div class="stat-icon stat-icon-red"><i class="bi bi-x-lg"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="products-table-card card w-100">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-3 gap-3">
                <form class="search-form flex-grow-1 me-3" method="get" asp-action="Product">
                    <div class="input-group search-group">
                        <span class="input-group-text search-icon"><i class="bi bi-search"></i></span>
                        <input name="q" value="@(ViewContext.HttpContext.Request.Query["q"])" type="text" class="form-control search-input" placeholder="Zoeken op naam, categorie of SKU..." />
                    </div>
                </form>
                <div class="text-muted ms-2">@Model.TotalCount artikelen</div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Naam</th>
                            <th>SKU</th>
                            <th>Categorie</th>
                            <th>Locatie</th>
                            <th class="text-end">Voorraad</th>
                            <th class="text-end">Min.</th>
                            <th class="text-end">Prijs/st.</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Items)
                        {
                            var badgeClass = p.Status == "Op voorraad" ? "status-success" : p.Status == "Laag voorraad" ? "status-warning" : "status-danger";
                            var iconClass = p.Status == "Op voorraad" ? "bi-check-circle" : p.Status == "Laag voorraad" ? "bi-exclamation-triangle" : "bi-x-circle";
                        <tr>
                            <td>@p.Name</td>
                            <td class="text-muted">@p.SKU</td>
                            <td>@p.Category</td>
                            <td>@p.Location</td>
                            <td class="text-end">@String.Format("{0:N0}", p.Stock)</td>
                            <td class="text-end">@String.Format("{0:N0}", p.Min)</td>
                            <td class="text-end">€@p.Price.ToString("0.00")</td>
                            <td class="text-center">
                                <span class="badge status-badge @badgeClass"><i class="bi @iconClass me-1"></i> @p.Status</span>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            var active = i == Model.Page ? "active" : "";
                            <li class="page-item @active">
                                <a class="page-link" href="@(Url.Action("Product", new { q = ViewContext.HttpContext.Request.Query["q"], page = i, pageSize = Model.PageSize }))">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>