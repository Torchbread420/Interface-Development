@model BackOffice.Controllers.ProductenController;
@{
    ViewData["Title"] = "Alle producten";
}
<section class="main">

    <div class="productenContainer">
        <form asp-action="BulkAction" method="post">
        @foreach ( var product in @Model.Producten)
        {
            <div class="product">
                <input type="checkbox" class="bulk-checkbox" asp-action="checkboxOn-@product.Id" />
                <div class="id-product">@product.Id</div>
                <div class="title-product">@product.Name</div>
                <div class="type-product">@product.Type</div>
                <div class="availability-product">@product.Availability</div>
                <div class="kostPrijs-product">@product.KostPrice</div>
                <div class="beschikbaarheid-product">@product.Price</div>
                <div class="btnContainer">
                    <button type="button" class="edit-product" asp-action="edit-product" asp-action-id="@product.Id">edit</button>
                        <button type="button" class="remove-product" asp-action="remove-product" asp-action-id="@product.Id">remove</button>
                </div>
            </div>
        }
            <button type="submit" class="bulk-action" name="action" value="edit">Edit Selected</button>
            <button type="submit" name="action" value="delete">Delete Selected</button>
        </form>
    </div>
</section>

<section class="product-editForm" data-hidden="true">
    <div class="left-side-container">
        <!-- Name -->
        <label for="edit-name">Name:</label>
        <input type="text" id="edit-name" name="edit-name" value="@Model?.ProductEditForm?.Name" />
        <!-- Type -->
        <label for="edit-type">Type:</label>
        <input type="text" id="edit-type" name="edit-type" value="@Model?.ProductEditForm?.Type" />
        <!-- Description -->
        <label for="edit-description">Description:</label>
        <input type="text" id="edit-description" name="edit-description" value="@Model?.ProductEditForm?.Description" />
        <!-- Availability -->
        <label for="edit-availability">Availability:</label>
        <input type="number" id="edit-availability" name="edit-availability" value="@Model?.ProductEditForm?.Availability" />
        <!-- min. Availability -->
        <label for="edit-min-availability">minimum Availability:</label>
        <input type="number" id="edit-min-availability" name="edit-min-availability" value="@Model?.ProductEditForm?.MinimumAvailablility" />
        <!-- Image path -->
        <label for="edit-imagePath">Image Path:</label>
        <input type="text" id="edit-imagePath" name="edit-imagePath" value="@Model?.ProductEditForm?.ImagePath" />
    </div>
    <div class="right-side-container">
        <!-- abs price -->
        <label for="edit-abs-price">Absolute Price:</label>
        <input type="number" id="edit-abs-price" name="edit-abs-price" value="@Model?.ProductEditForm?.Price" /><span class="currency">€</span>
        <!-- kost price -->
        <label for="edit-kost-price">Cost Price:</label>
        <input type="number" id="edit-kost-price" name="edit-kost-price" value="@Model?.ProductEditForm?.KostPrice" /><span class="currency">€</span>
        <!-- sale price -->
        <label for="edit-sale-price">Sale Price:</label>
        <input type="number" id="edit-sale-price" name="edit-sale-price" value="@Model?.ProductEditForm?.SalePrice" /><span class="percentage">%</span>
        
    </div>
</section>

<section class="product-remove-confirmation">

</section>
