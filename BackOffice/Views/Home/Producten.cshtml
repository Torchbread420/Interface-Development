@model BackOffice.DataAccessLayer.Models.ProductenViewModel;
@{
    ViewData["Title"] = "Alle producten";
}
<section class="main">

    <div class="productenContainer">
        <form asp-action="BulkAction" method="post">
        @foreach ( var product in @Model.Producten)
        {
            <div class="product">
                <input type="checkbox" class="bulk-checkbox" name="selectedIds" value="@product.Id" />
                <div class="id-product">@product.Id</div>
                <div class="title-product">@product.Name</div>
                <div class="type-product">@product.Type</div>
                <div class="availability-product">@product.Availability</div>
                <div class="kostPrijs-product">@product.KostPrice</div>
                <div class="beschikbaarheid-product">@product.Price</div>
                <div class="btnContainer">
                        <a asp-action="Edit" asp-route-id="@product.Id" class="edit-product" >Edit</a>
                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="id" value="@product.Id" />
                            <button type="submit" class="remove-product">Remove</button>
                        </form>
                </div>
            </div>
        }
            <button type="submit" class="bulk-action" name="action" value="edit">Edit Selected</button>
            <button type="submit" name="action" value="delete">Delete Selected</button>
        </form>
    </div>
</section>

<section class="product-editForm" data-hidden="true">
    
</section>

<section class="product-remove-confirmation">
    <h3 class="removeConfirmation-text">weet je zeker dat je dit item wilt verwijderen?</h3>
    <div class="buttonContainer">
        <button class="removeConfirmation-cancel-btn removeConfirmation-Btn" asp-action="removeConfirmation-Cancel">Cancel</button>
        <button class="removeConfirmation-save-btn removeConfirmation-Btn" asp-action="removeConfirmation-save">Save</button>
    </div>
</section>

<section class="product-bulk-edit">
    <h4 class="bulkEdit-text">Vervang alle geselecteerde info</h4>
    <!-- abs price -->
    <label for="bulkEdit-absPrice">Absolute Price:</label>
    <input type="number" id="bulkEdit-absPrice" name="bulkEdit-absPrice" value="@Model?.BulkEdit?.AbsolutePrice" /><span class="currency">€</span>
    <!-- sale percentage -->
    <label for="bulkEdit-sale">korting / verhoging</label>
    <input type="number" id="bulkEdit-sale" name="bulkEdit-sale" value="@Model?.BulkEdit?.SalePercentage" /><span class="percentage">%</span>
</section>