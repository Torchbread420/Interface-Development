@{
    ViewData["Title"] = "Home";
}

<!-- Pagina titel -->
<h4 class="mb-4">Home</h4>

<!-- ============================================
     SECTIE 1: STATISTIEKEN KAARTEN
     Toont 3 kaarten met totalen uit de database.
     De data komt uit ViewBag (gevuld in HomeController).
     ============================================ -->
<h6 class="text-muted mb-3">Statistieken</h6>
<div class="row mb-4">

    <!-- Kaart 1: Totaal aantal producten -->
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Producten</p>
                    <!-- @ViewBag.TotalProducts wordt in de controller gezet -->
                    <h3 class="mb-1">@ViewBag.TotalProducts</h3>
                    <small class="text-muted">In catalogus</small>
                </div>
                <span class="stat-icon stat-icon-blue">
                    <i class="bi bi-box-seam"></i>
                </span>
            </div>
        </div>
    </div>

    <!-- Kaart 2: Totaal aantal bestellingen -->
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Bestellingen</p>
                    <h3 class="mb-1">@ViewBag.TotalOrders</h3>
                    <small class="text-muted">Totaal geplaatst</small>
                </div>
                <span class="stat-icon stat-icon-red">
                    <i class="bi bi-cart-check"></i>
                </span>
            </div>
        </div>
    </div>

    <!-- Kaart 3: Totaal aantal klanten -->
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Klanten</p>
                    <h3 class="mb-1">@ViewBag.TotalCustomers</h3>
                    <small class="text-muted">Actieve klanten</small>
                </div>
                <span class="stat-icon stat-icon-green">
                    <i class="bi bi-people"></i>
                </span>
            </div>
        </div>
    </div>
</div>
<!-- ============================================
     SECTIE 2: GRAFIEK + SNELLE ACTIES
     Links: lijndiagram met Chart.js (bestellingen per maand)
     Rechts: snelkoppelingen naar veelgebruikte acties
     ============================================ -->
<div class="row mb-4">

    <!-- Linkerkolom: Grafiek (8 van 12 kolommen breed) -->
    <div class="col-md-8">
        <div class="card stat-card">
            <div class="card-body">
                <h6>Bestellingen per maand</h6>
                <!-- Canvas element waar Chart.js de grafiek in tekent -->
                <!-- Het script onderaan de pagina vult dit canvas -->
                <canvas id="ordersChart" height="200"></canvas>
            </div>
        </div>
    </div>

    <!-- Rechterkolom: Snelle acties (4 van 12 kolommen) -->
    <!-- h-100 zorgt dat deze kaart even hoog is als de grafiek -->
    <div class="col-md-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <h6>Snelle acties</h6>

                <!-- Actie 1: Link naar producten pagina -->
                <a asp-controller="Producten" asp-action="Index" class="quick-action-link">
                    <i class="bi bi-plus-circle text-primary"></i>
                    <div>
                        <strong>Nieuw Product</strong>
                        <small class="text-muted d-block">Voeg onderdeel toe</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>

                <!-- Actie 2: Personeel (nog geen pagina, dus href="#") -->
                <a href="#" class="quick-action-link">
                    <i class="bi bi-plus-circle text-primary"></i>
                    <div>
                        <strong>Nieuw Personeel</strong>
                        <small class="text-muted d-block">Voeg medewerker toe</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>

                <!-- Actie 3: Notitie (nog geen pagina, dus href="#") -->
                <a href="#" class="quick-action-link">
                    <i class="bi bi-plus-circle text-primary"></i>
                    <div>
                        <strong>Nieuwe Notitie</strong>
                        <small class="text-muted d-block">Maak een aantekening</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>
<!-- ============================================
     SECTIE 3: MELDINGEN
     Gekleurde meldingsrijen. Voorlopig hardcoded.
     Kleuren: warning=oranje, info=blauw, success=groen
     ============================================ -->
<div class="card stat-card mb-4">
    <div class="card-body">
        <!-- Header met titel en badge -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0"><i class="bi bi-bell"></i> Meldingen</h6>
            <span class="badge bg-danger rounded-pill">4 nieuw</span>
        </div>

        <!-- Melding 1: Voorraad waarschuwing -->
        <div class="melding melding-warning">
            <span>Tandwiel 16T voorraad bijna op (8 stuks)</span>
            <small class="text-muted">2 uur geleden</small>
        </div>

        <!-- Melding 2: Nieuwe bestelling -->
        <div class="melding melding-info">
            <span>Nieuwe bestelling #6 ontvangen van Sophie Mol</span>
            <small class="text-muted">3 uur geleden</small>
        </div>

        <!-- Melding 3: Bestelling afgerond -->
        <div class="melding melding-success">
            <span>Bestelling #5 voltooid — Borgmoer Set</span>
            <small class="text-muted">5 uur geleden</small>
        </div>

        <!-- Melding 4: Lage voorraad -->
        <div class="melding melding-warning">
            <span>Inbus Schroef M6 voorraad laag (850 stuks)</span>
            <small class="text-muted">1 dag geleden</small>
        </div>
    </div>
</div>
<!-- ============================================
     SECTIE 4: RECENTE ORDERS TABEL
     Haalt orders dynamisch op uit ViewBag.RecentOrders.
     De foreach loopt over alle orders uit de database.
     ============================================ -->
<div class="card stat-card mb-4">
    <div class="card-body">
        <!-- Header met link naar alle orders -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0">Recente Orders</h6>
            <a href="#" class="text-primary text-decoration-none">Alle orders <i class="bi bi-chevron-right"></i></a>
        </div>

        <!-- Tabel met orders -->
        <table class="table table-borderless">
            <thead>
                <tr class="text-muted">
                    <th>Naam</th>
                    <th>Klant</th>
                    <th>Datum</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <!-- Loop over alle orders uit de database -->
                <!-- ViewBag.RecentOrders is een List<Order> gezet in HomeController -->
                @foreach (var order in (List<DataAccessLayer.Models.Order>)ViewBag.RecentOrders)
                {
                    <tr>
                        <td>Bestelling #@order.Id</td>
                        <!-- Customer.Name toont de naam van de gekoppelde klant -->
                        <td>@order.Customer?.Name</td>
                        <!-- Datum formatteren als dd-MM-yyyy (Nederlands formaat) -->
                        <td>@order.OrderDate.ToString("dd-MM-yyyy")</td>
                        <td><span class="badge bg-success">Voltooid</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- ============================================
     CHART.JS SCRIPT
     Replaced the Razor section with a plain script block to avoid "Unexpected literal following the 'section' directive" (RZ1017).
     If you rely on a layout section, ensure the layout defines RenderSection("Scripts") and that this view is not used as a partial.
     ============================================ -->
<script>
    // Haal het canvas element op waar de grafiek in komt
    var ctx = document.getElementById('ordersChart').getContext('2d');

    // Maak een nieuwe Chart.js lijndiagram
    new Chart(ctx, {
        type: 'line',  // Type grafiek: lijn
        data: {
            // X-as labels: maanden
            labels: ['Jan', 'Feb', 'Mrt', 'Apr', 'Mei', 'Jun'],
            datasets: [
                {
                    // Dataset 1: Blauwe lijn voor bestellingen
                    label: 'Bestellingen',
                    data: [2, 4, 3, 5, 4, 6],
                    borderColor: '#4285f4',                  // Lijnkleur: blauw
                    backgroundColor: 'rgba(66, 133, 244, 0.1)', // Vulkleur: lichtblauw
                    fill: true,      // Vul het gebied onder de lijn
                    tension: 0.4     // Maak de lijn vloeiend (0 = recht, 1 = heel rond)
                },
                {
                    // Dataset 2: Rode lijn voor afgeleverde orders
                    label: 'Afgeleverd',
                    data: [1, 3, 2, 4, 3, 5],
                    borderColor: '#ea4335',
                    backgroundColor: 'rgba(234, 67, 53, 0.1)',
                    fill: true,
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,  // Past zich aan aan schermgrootte
            plugins: {
                legend: {
                    position: 'bottom'  // Legenda onder de grafiek
                }
            },
            scales: {
                y: {
                    beginAtZero: true  // Y-as begint altijd bij 0
                }
            }
        }
    });
</script>