@{
    ViewData["Title"] = "Home";
}

<h4 class="mb-4">Home</h4>

<!-- Statistieken -->
<h6 class="text-muted mb-3">Statistieken</h6>
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Omzet</p>
                    <h3 class="mb-1">€30.000</h3>
                    <small class="text-success"><i class="bi bi-arrow-up-right"></i> +12% vs vorige maand</small>
                </div>
                <span class="stat-icon stat-icon-blue">
                    <i class="bi bi-currency-euro"></i>
                </span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Kosten</p>
                    <h3 class="mb-1">€21.000</h3>
                    <small class="text-success"><i class="bi bi-arrow-up-right"></i> +5% vs vorige maand</small>
                </div>
                <span class="stat-icon stat-icon-red">
                    <i class="bi bi-currency-euro"></i>
                </span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Winst</p>
                    <h3 class="mb-1">€9.000</h3>
                    <small class="text-danger"><i class="bi bi-arrow-down-right"></i> +18% vs vorige maand</small>
                </div>
                <span class="stat-icon stat-icon-green">
                    <i class="bi bi-graph-up"></i>
                </span>
            </div>
        </div>
    </div>
</div>