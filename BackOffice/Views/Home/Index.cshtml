@{
    ViewData["Title"] = "Home";
}

<h4 class="mb-4">Home</h4>
<h6 class="text-muted mb-3">Statistieken</h6>
<div class="row mb-4">

    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Producten</p>
                    <h3 class="mb-1">@ViewBag.TotalProducts</h3>
                    <small class="text-muted">In catalogus</small>
                </div>
                <span class="stat-icon stat-icon-blue">
                    <i class="bi bi-box-seam"></i>
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Bestellingen</p>
                    <h3 class="mb-1">@ViewBag.TotalOrders</h3>
                    <small class="text-muted">Totaal geplaatst</small>
                </div>
                <span class="stat-icon stat-icon-red">
                    <i class="bi bi-cart-check"></i>
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1">Klanten</p>
                    <h3 class="mb-1">@ViewBag.TotalCustomers</h3>
                    <small class="text-muted">Actieve klanten</small>
                </div>
                <span class="stat-icon stat-icon-green">
                    <i class="bi bi-people"></i>
                </span>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">

    <div class="col-md-8">
        <div class="card stat-card">
            <div class="card-body">
                <h6>Bestellingen per maand</h6>
                <canvas id="ordersChart" height="200"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <h6>Snelle acties</h6>

                <a href="#" class="quick-action-link">
                    <i class="bi bi-plus-circle text-primary"></i>
                    <div>
                        <strong>Nieuw Product</strong>
                        <small class="text-muted d-block">Voeg onderdeel toe</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>

                <a href="#" class="quick-action-link">
                    <i class="bi bi-plus-circle text-primary"></i>
                    <div>
                        <strong>Nieuwe Notitie</strong>
                        <small class="text-muted d-block">Maak een aantekening</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card stat-card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0"><i class="bi bi-bell"></i> Meldingen</h6>
            <span class="badge bg-danger rounded-pill">4 nieuw</span>
        </div>

        <div class="melding melding-warning">
            <span>Tandwiel 16T voorraad bijna op (8 stuks)</span>
            <small class="text-muted">2 uur geleden</small>
        </div>

        <div class="melding melding-info">
            <span>Nieuwe bestelling #6 ontvangen van Sophie Mol</span>
            <small class="text-muted">3 uur geleden</small>
        </div>

        <div class="melding melding-success">
            <span>Bestelling #5 voltooid — Borgmoer Set</span>
            <small class="text-muted">5 uur geleden</small>
        </div>

        <div class="melding melding-warning">
            <span>Inbus Schroef M6 voorraad laag (850 stuks)</span>
            <small class="text-muted">1 dag geleden</small>
        </div>
    </div>
</div>

<div class="card stat-card mb-4">
    <div class="card-body">
        <!-- Header met link naar alle orders -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0">Recente Orders</h6>
            <a href="#" class="text-primary text-decoration-none">Alle orders <i class="bi bi-chevron-right"></i></a>
        </div>

        <!-- Tabel met orders -->
        <table class="table table-borderless">
            <thead>
                <tr class="text-muted">
                    <th>Naam</th>
                    <th>Klant</th>
                    <th>Datum</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in (List<DataAccessLayer.Models.Order>)ViewBag.RecentOrders)
                {
                    <tr>
                        <td>Bestelling #@order.Id</td>
                        <td>@order.User?.Name</td>
                        <td>@order.OrderDate.ToString("dd-MM-yyyy")</td>
                        <td><span class="badge bg-success">Voltooid</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>